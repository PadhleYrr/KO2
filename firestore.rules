rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Current affairs (read by all logged-in users) ──────────────
    match /currentAffairsFlat/{doc} {
      allow read: if request.auth != null;
      allow write: if false; // only Cloud Function writes
    }

    // ── Community posts ───────────────────────────────────────────
    match /communityPosts/{postId} {
      allow read: if request.auth != null;

      // Create: must be logged in, authorUid must match, title required
      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 300;

      // Update: author can edit all; others can only touch like/upvote/commentCount fields
      allow update: if request.auth != null && (
        request.resource.data.authorUid == resource.data.authorUid
        || (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likes', 'likedBy', 'upvotes', 'upvotedBy', 'commentCount'])
        )
      );

      // Delete: only by author
      allow delete: if request.auth != null
        && resource.data.authorUid == request.auth.uid;

      // ── Comments subcollection ──────────────────────────────────
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.body is string
          && request.resource.data.body.size() > 0;
        allow update: if request.auth != null && (
          resource.data.authorUid == request.auth.uid
          || request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['likes', 'likedBy'])
        );
        allow delete: if request.auth != null
          && resource.data.authorUid == request.auth.uid;
      }
    }

    // ── Global chat ───────────────────────────────────────────────
    match /globalChat/{msgId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 1000;
      allow update, delete: if false; // chat messages are immutable
    }

    // ── Users ─────────────────────────────────────────────────────
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Subscriptions / config ────────────────────────────────────
    match /config/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
